{
  "appId": "com.pragma.stoic",
  "appName": "Pragma",
  "webDir": "public",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#03010a",
    "splash": {
      "backgroundColor": "#03010a",
      "showSpinner": false
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 500,
      "backgroundColor": "#03010a",
      "androidSpinnerStyle": "none",
      "showSpinner": false
    }
  }
}
